# --- Browser (Vite) — safe to expose in the built JS bundle ---
VITE_GOOGLE_SHEETS_SYNC=1

# One Google Sheet per navbar company (ids from …/spreadsheets/d/THIS/edit)
VITE_GOOGLE_SHEET_ID_AADARSH=
VITE_GOOGLE_SHEET_ID_DEVA=
VITE_GOOGLE_SHEET_ID_SANGITA=

# Default /api/billing is proxied to the Node server in dev.
# VITE_BILLING_API_BASE=https://your-api.example.com/api/billing
# VITE_BILLING_API_SECRET=

# --- Node billing API (no VITE_*) — .env or .env.local next to package.json ---
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=google-sa-key.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: master spreadsheet — tab "AppData", cell A1 = app JSON (cloud backup). Omit = localStorage only.
# BILLING_MASTER_SPREADSHEET_ID=

# BILLING_API_PORT=8787
# BILLING_API_SECRET=
