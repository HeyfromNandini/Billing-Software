# Copy to .env.local and fill in from Firebase Console → Project settings → Your apps → Web app config.
# If any of these are missing, the app uses browser localStorage only (same as before).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
